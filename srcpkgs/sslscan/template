pre_build() {
	sed -i 's/-lssl/-lssl -lcrypto/g' Makefile
	sed -i "s/gcc -g/$CC $CFLAGS/g" Makefile
}
do_install() {
	vmkdir usr/bin
	vmkdir usr/share/man/man1
	make BINPATH=${DESTDIR}/usr/bin/ MANPATH=${DESTDIR}/usr/share/man/ install
}
