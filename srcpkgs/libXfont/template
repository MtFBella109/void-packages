libXfont-devel_package() {
	depends="xproto fontsproto zlib-devel libfontenc-devel freetype-devel
		libXfont-${version}_${revision}"
	short_desc="${short_desc} -- development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
