# Template file for 'cosmic-player'
pkgname=cosmic-player
version=1.1.0
revision=2
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="pkg-config just cargo cargo-auditable $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel gstreamer1-devel gst-plugins-base1-devel "
depends="libxkbcommon gst-plugins-base1 gst-plugins-good1"
short_desc="Cosmic Media Player"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-player"
distfiles="https://github.com/pop-os/cosmic-player/archive/refs/tags/epoch-${version}.tar.gz"
checksum=d3ccb0fcbd3ae82ba9efe1d9f0b9822d09f7a5f3abb94dd08199adf4a73d2881
build_options="sccache"
if [ "$XBPS_LIBC" = "glibc" ]; then
	makedepends+=" libglib-devel"
fi

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
