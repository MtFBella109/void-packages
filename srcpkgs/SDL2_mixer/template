pre_configure() {
	sed -e "/CONFIG_FILE_ETC/s|/etc/timidity.cfg|/etc/timidity++/timidity.cfg|" \
		-e "/DEFAULT_PATH/s|/etc/timidity|/etc/timidity++|" \
		-e "/DEFAULT_PATH2/s|/usr/local/lib/timidity|/usr/lib/timidity|" \
		-i timidity/config.h
}
