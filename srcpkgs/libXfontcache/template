	depends="fontcacheproto libXfontcache>=${version}"
	short_desc+=" -- development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove usr/share
	}
}

