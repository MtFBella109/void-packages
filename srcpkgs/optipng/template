do_configure() {
	./configure -prefix=/usr -mandir=/usr/share/man -with-system-libpng -with-system-zlib
}

do_build() {
	make LD="$CC" ${makejobs}
}

do_install() {
	make LD="$CC" DESTDIR=$DESTDIR install
}
