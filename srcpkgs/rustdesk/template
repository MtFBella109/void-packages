# Template file for 'rustdesk'
pkgname=rustdesk
version=1.4.6
revision=1
build_helper=rust
hostmakedepends="pkg-config git cargo clang21 cmake ninja"
makedepends="autoconf automake unzip nasm yasm gstreamer1-devel gst-plugins-base1-devel gtk+3-devel libtool gettext alsa-lib-devel pam-devel pipewire-devel wget curl tar libopusenc-devel libaom-devel libsodium-devel libxcb-devel libvpx-devel wayland-devel libXfixes-devel xdotool-devel zip"
depends="libX11 libXfixes libXtst cairo libcrypto3 dbus-libs libgcc gtk+3 gdk-pixbuf glib gst-plugins-base1 gstreamer1 pango libsodium libssl3 libstdc++ libxcb xdotool libxkbcommon libzstd"
short_desc="Alternative to AnyDesk"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="AGPL-3.0"
homepage="https://github.com/rustdesk/rustdesk"

pre_fetch() {
	if [ -d $wrksrc ]; then
		rm -rf $wrksrc
		mkdir $wrksrc
	fi
}

do_fetch() {
	git clone --recurse-submodules $homepage $wrksrc
	cd $wrksrc
	git checkout $version
	wget https://raw.githubusercontent.com/c-smile/sciter-sdk/master/bin.lnx/x64/libsciter-gtk.so
	echo a1682fbf55e004f1862d6ace31b5220121d20906bdbf308d0a9237b451e4db86 libsciter-gtk.so | sha256sum -c
	git clone https://github.com/microsoft/vcpkg $wrksrc/vcpkg
	cd $wrksrc/vcpkg
	git checkout 2026.04.27
	./bootstrap-vcpkg.sh
}
do_build() {
	export VCPKG_ROOT=$wrksrc/vcpkg
	#vcpkg/vcpkg install --x-install-root=$VCPKG_ROOT/installed --disable-metrics
	#VCPKG_ROOT=$wrksrc/vcpkg cargo build --release
	cargo build  --lib --release
	strip target/release/rustdesk
}

do_install() {
	vcopy libsciter-gtk.so usr/lib
	#vcopy target/release/librustdesk.so usr/lib
	vbin target/release/rustdesk
	strip ${DESTDIR}usr/bin/rustdesk
	vlicense LICENCE

}
