post_install() {
	# Remove unused stuff
	rm -rf ${DESTDIR}/usr/share/man
	rm -f ${DESTDIR}/usr/bin/plaympeg
}

smpeg-devel_package() {
	depends="sdl12-compat-devel smpeg>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/bin
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/share
	}
}
