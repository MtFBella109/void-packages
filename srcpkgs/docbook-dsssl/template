do_install() {
	rm -rf ${wrksrc}/docsrc
	vmkdir usr/share/sgml/docbook/dsssl/modular
	cp -rp ${wrksrc}/* ${DESTDIR}/usr/share/sgml/docbook/dsssl/modular
	sed -n '/Copyright/,/exist/p' README > LICENSE
	vlicense LICENSE
}
