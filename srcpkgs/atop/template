pre_install() {
	vsed -e 's,sbin,bin,g' \
		-e '/$(DEFPATH)/d' -i Makefile
	vsed -e 's,bin/sh,bin/bash,' -i atop.daily
}

post_install() {
	vsv atop
	# Remove unused stuff.
	rm -f ${DESTDIR}/usr/bin/atop{,sar}-${version}
	rm -rf ${DESTDIR}/etc/init.d ${DESTDIR}/var
}
