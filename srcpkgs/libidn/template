libidn-devel_package() {
	depends="libidn>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/share/man/man3
		vmove usr/share/emacs
		vmove usr/share/info
		vmove "usr/lib/*.so"
	}
}
