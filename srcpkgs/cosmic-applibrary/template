# Template file for 'cosmic-applibrary'
pkgname=cosmic-applibrary
version=1.1.0
revision=2
archs="x86_64* i686"
build_style="cargo"
configure_args="--all"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel "
depends="libxkbcommon"
short_desc="Cosmic App Library"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-applibrary"
distfiles="https://github.com/pop-os/cosmic-applibrary/archive/refs/tags/epoch-${version}.tar.gz"
checksum=6080d58ef3e25ffa4537944b9108fdfd3e099d907380fb90c18cd31b97639bad
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	CARGO_TARGET_DIR="target/${RUST_TARGET}" just rootdir=${DESTDIR} install
}
