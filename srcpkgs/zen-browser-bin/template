# Template file for 'zen-browser-bin'
pkgname=zen-browser-bin
version=1.20b
revision=1
hostmakedepends="pkg-config"
depends="gtk+3 libstdc++  pango atk cairo gdk-pixbuf glib libxcb libX11 libXext libXrandr libXcomposite libXcursor libXdamage libXfixes libXi libXrender alsa-lib freetype fontconfig dbus-libs"
short_desc="New Browser based on Firefox"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="MPL-2.0"
homepage="https://github.com/zen-browser/desktop"
distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-x86_64.tar.xz"
checksum=51d91cbc7b1bcb20df34553ccf73f31cc55cdaf9d36136d62501c546dcd97e58
replaces="zen-browser=>0"

do_install() {
	vmkdir usr/lib/zen-browser
	vcopy * usr/lib/zen-browser
	vmkdir usr/bin
	ln -s /usr/lib/zen-browser/zen usr/bin/
	vinstall ${FILESDIR}/zen-browser.desktop 644 usr/share/applications/
	for size in 16 32 48 64 128; do
		vinstall browser/chrome/icons/default/zen-browser.png 644 usr/share/icons/hicolor/${size}x${size}/apps/
	done
}
