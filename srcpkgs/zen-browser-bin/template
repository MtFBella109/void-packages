# Template file for 'zen-browser-bin'
pkgname=zen-browser-bin
version=1.21b
revision=1
#depends="libXt libXtst libxkbcommon libxkbcommon-x11 libpng"
archs="x86_64 aarch64"
short_desc="New Browser based on Firefox"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="MPL-2.0"
homepage="https://github.com/zen-browser/desktop"
distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-x86_64.tar.xz
 https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-aarch64.tar.xz"
checksum="a1473c843465a0683f5f300edfd5c358c6e2d0588392b0e16c6f826ad9d678b9
 25b33e6ac9c04efbfb2e5e3ca49c1b09f4ec0477e20e1f8aa077d51f5d4a4a43"
replaces="zen-browser>=0 zen-browser-arm64-bin>=0"

do_extract() {
	local archiv
	case "$XBPS_TARGET_MACHINE" in
		x86_64)      archiv="zen.linux-x86_64.tar.xz" ;;
		aarch64)     archiv="zen.linux-aarch64.tar.xz" ;;
	esac
	vextract "${XBPS_SRCDISTDIR}/${pkgname}-${version}/${archiv}"
}

do_install() {
	vmkdir usr/lib/zen-browser
	vcopy * usr/lib/zen-browser

	vinstall ${FILESDIR}/zen-browser.desktop 644 usr/share/applications
	for size in 16 32 48 64 128; do
		vinstall browser/chrome/icons/default/default${size}.png 644 usr/share/icons/hicolor/${size}x${size}/apps zen-browser.png
	done

	vbin ${FILESDIR}/zen-browser
}
