pre_configure() {
	case "${XBPS_TARGET_MACHINE}" in
		*-musl) sed -i -e "s/^host_os=.*/host_os=gnu/" configure
	esac
}

mdbtools-devel_package() {
	depends="libmdb>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}

libmdb_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}
