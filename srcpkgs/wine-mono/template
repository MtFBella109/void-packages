do_install() {
	# The actual installation within WINE occurs at runtime in whatever
	# WINEPREFIX is being used.
	vinstall ${pkgname}-${version}-x86.msi 644 usr/share/wine/mono
	vlicense ${FILESDIR}/COPYING
}
