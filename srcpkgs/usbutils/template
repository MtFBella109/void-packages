post_install() {
	# Remove lsusb.py - avoid useless python scripts
	rm ${DESTDIR}/usr/bin/lsusb.py
	rm ${DESTDIR}/usr/share/man/man1/lsusb.py.1
	# add usbreset, upstream doesn't install it by default
	vbin build/usbreset
	vman man/usbreset.1
