pre_configure() {
	sed -i 's,-L$(libdir),,g' cython/Makefile.am
	export PYTHON_CPPFLAGS=" -I${XBPS_CROSS_BASE}/${py3_inc}"
	export PYTHON_LDFLAGS=" -L${XBPS_CROSS_BASE}/usr/lib -lpython${py3_ver}"
	autoreconf -fi
	sed -i "s#\$PYTHON-config#__DOES_NOT_EXIST__#" configure
}

