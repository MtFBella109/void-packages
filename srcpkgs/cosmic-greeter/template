# Template file for 'cosmic-greeter'
pkgname=cosmic-greeter
version=1.3.0
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
#configure_args="--all  --no-dfeault-features"
hostmakedepends="pkg-config just"
makedepends="libxkbcommon-devel eudev-libudev-devel git pam-devel libinput-devel llvm18-devel"
depends="greetd libxkbcommon pam-libs"
short_desc="COSMIC Display Manager"
maintainer="Bella109 <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-greeter"
distfiles="https://github.com/pop-os/cosmic-greeter/archive/refs/tags/epoch-${version}.tar.gz"
