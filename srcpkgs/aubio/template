libaubio_package() {
	short_desc+=" - Runtime libraries"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

aubio-devel_package() {
	depends="libaubio-${version}_${revision}"
	short_desc+=" - Development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}
