do_install() {
	make -R install prefix=/usr DESTDIR=${DESTDIR}

	# Remove dup manpages.
	cd ${DESTDIR}/usr/share/man
	# coreutils
	rm -f man1/{chgrp,chmod,chown,cp,dir,dd}.1
