do_install()
{
	cd ${wrksrc} || retuyrn 1
	install -d ${DESTDIR}/usr/lib/mozilla/plugins \
		   ${DESTDIR}/usr/share/doc/${pkgname} || return 1
	tar xfz "${XBPS_SRCDISTDIR}/$(basename ${_disttarball})" || return 1
	install -m755 install_flash_player_10_linux/libflashplayer.so \
