# Template file for 'cosmic-edit'
pkgname=cosmic-edit
version=1.1.0
revision=1
archs="x86_64*"
build_style=cargo
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel oniguruma-devel libzstd-devel libglib-devel"
depends="libxkbcommon libzstd oniguruma"
short_desc="COSMIC Text Editor"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-edit"
distfiles="https://github.com/pop-os/cosmic-edit/archive/refs/tags/epoch-${version}.tar.gz"
checksum=8a254c3fc067f472f6b8f25880c8823b905b777647c136224f1da42e38464746
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
