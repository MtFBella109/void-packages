post_install() {
	for f in ${DESTDIR}/usr/share/man/man3/*.3tiff; do
		mv ${f} ${f%tiff}
	done
	vlicense LICENSE.md
}

tiff-devel_package() {
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/share/man/man3
		vmove usr/share/doc
	}
}
