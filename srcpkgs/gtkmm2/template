gtkmm2-devel_package() {
	depends="${makedepends} gtkmm2-${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/g*"
		vmove "usr/lib/*.so"
	}
}
