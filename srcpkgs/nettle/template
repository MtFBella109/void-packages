nettle-devel_package() {
	depends="gmp-devel ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
		vmove usr/share/info
	}
}

nettle-tools_package() {
	short_desc+=" - bundled tools"
	pkg_install() {
		vmove usr/bin
	}
}
