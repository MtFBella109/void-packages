libepc-devel_package() {
	depends="gtk+3-devel avahi-glib-libs-devel libsoup-devel libepc>=${version}"
	short_desc="${short_desc} - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/share/gtk-doc
		vmove usr/lib/pkgconfig
	}
}

