libgnome-keyring-devel_package() {
	depends="libglib-devel ${sourcepkg}>=${version}"
	short_desc="${short_desc} -- development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/share/gir-1.0
		vmove usr/share/gtk-doc
	}
}

