do_configure() {
	python2 mscript.py configure --prefix=/usr --cc="$CC" --cpp="$CPP" --cxx="$CXX" --ld="$LD"
}
do_build() {
	python2 mscript.py build --cc="$CC" --cpp="$CPP" --cxx="$CXX" --ld="$LD" --cflags="$CFLAGS" --ldflags="$LDFLAGS"
}
do_install() {
	python2 mscript.py install --destdir=${DESTDIR}
}
