do_install() {
	make DIST_DIR=${DESTDIR}/usr install
	vlicense LICENSE
}

libvpx-tools_package() {
	short_desc+=" - tools"
	pkg_install() {
		vmove usr/bin
	}
}

libvpx-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
	}
}

