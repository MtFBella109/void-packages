libcec-devel_package() {
	short_desc+=" - development files"
	depends="eudev-libudev-devel p8-platform-devel libcec>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
	}
}

cec-client_package() {
	depends="libcec>=${version}"
	short_desc="${short_desc} -- client tool"
	pkg_install() {
		vmove usr/bin
	}
}

libcec_package() {
	pkg_install() {
		vmove usr
	}
}
