 $(vopt_enable gdbserver) $(vopt_if multiarch --enable-targets=all)
 $(vopt_if static 'CFLAGS=-static CXXFLAGS=-static LDFLAGS=-static')
 $(vopt_with guile) $(vopt_if python --with-python=/usr/bin/python3)
