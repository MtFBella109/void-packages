pre_configure() {
	sed 's/AM_CONFIG_HEADER/AC_CONFIG_HEADERS/g' \
		configure.in >configure.ac
	sed 's/AM_CONFIG_HEADER/AC_CONFIG_HEADERS/g' \
		libltdl/configure.in >libltdl/configure.ac
	autoreconf -fi
}

libmcrypt-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/bin
		vmove usr/share
	}
}
