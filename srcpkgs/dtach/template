do_build()
{
	./configure --prefix=/usr
	make ${makejobs}
}

do_install()
{
	install -Dm755 dtach "${DESTDIR}/usr/bin/dtach"
	install -Dm644 dtach.1 "${DESTDIR}/usr/share/man/man1/dtach.1"
