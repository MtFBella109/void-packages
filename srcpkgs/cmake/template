	depends="desktop-file-utils shared-mime-info cmake>=${version}"
	pkg_install() {
		vmove usr/bin/cmake-gui
		vmove usr/share/man/man1/cmake-gui.1

		vmove usr/share/applications
		vmove usr/share/icons
		vmove usr/share/mime
	}
