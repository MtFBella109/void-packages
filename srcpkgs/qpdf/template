libqpdf_package() {
	short_desc+=" - shared library"
	pkg_install() {
	vmove "usr/lib/*.so.*"
	}
}

libqpdf-devel_package() {
	depends="libqpdf>=${version}_${revision} libjpeg-turbo zlib-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/lib/cmake
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
