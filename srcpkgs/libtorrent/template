pre_configure() {
	autoreconf -fi
	sed -e 's,test "$cross_compiling" = yes, false,' -i configure
}

post_configure() {
	# Replace wrong (for cross buidls) -L/lib in Makefiles
	for f in $(find ${wrksrc} -name Makefile); do
		sed -i $f -e "s;-L/lib;-L${XBPS_CROSS_BASE}/lib;g"
	done
}

