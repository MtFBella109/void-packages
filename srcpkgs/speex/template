speex-devel_package() {
	depends="speexdsp-devel libspeex-${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/*.a
		vmove usr/lib/*.so
		vmove usr/share/doc
		vmove usr/share/aclocal
