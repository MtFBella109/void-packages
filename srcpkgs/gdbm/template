post_install() {
	# create symlinks for compatibility
	vmkdir usr/include/gdbm
	ln -sf ../gdbm.h ${DESTDIR}/usr/include/gdbm/gdbm.h
	ln -sf ../ndbm.h ${DESTDIR}/usr/include/gdbm/ndbm.h
	ln -sf ../dbm.h ${DESTDIR}/usr/include/gdbm/dbm.h
}

