do_install()
{
	gunzip -c ${XBPS_SRCDISTDIR}/unifont-${version}.bdf.gz \
		> unifont-${version}.bdf
	vinstall unifont-${version}.bdf \
		644 usr/share/fonts/misc unifont.bdf
