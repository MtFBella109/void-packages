do_install() {
	vinstall Makefile 644 usr/src/${pkgname}-${version}
	vinstall bbswitch.c 644 usr/src/${pkgname}-${version}
	sed "s,#MODULE_VERSION#,${version}," dkms/dkms.conf > \
		${DESTDIR}/usr/src/${pkgname}-${version}/dkms.conf
}
