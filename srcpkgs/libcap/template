pre_build()
{
	sed -i -e "s|LIBDIR=\$(FAKEROOT)\$(lib_prefix)\/lib|LIBDIR=\$(FAKEROOT)/\$(lib)|g" \
		${wrksrc}/Make.Rules
}

post_install()
{
	install -D -m644 ${wrksrc}/pam_cap/capability.conf \
		${DESTDIR}/etc/security/capability.conf
	mkdir -p ${DESTDIR}/lib
	mv ${DESTDIR}/usr/lib/security ${DESTDIR}/lib
