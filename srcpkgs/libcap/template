if [ "$CROSS_BUILD" ]; then
	make_build_args+=" CROSS_COMPILE=${XBPS_CROSS_TRIPLET}-"
fi

if [ "$CHROOT_READY" ]; then
	hostmakedepends="gperf"
	makedepends="pam-devel"
	make_build_args+=" PAM_CAP=yes"
	subpackages+=" libcap-pam"
