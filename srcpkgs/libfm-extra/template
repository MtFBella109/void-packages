post_install() {
	# Remove conflicting symlink with libfm.
	rm ${DESTDIR}/usr/include/libfm
}

libfm-extra-devel_package() {
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" -- development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.so
		vmove usr/lib/pkgconfig
	}
}
