eog-devel_package() {
	depends="${sourcepkg}>=${version}_${revision} gtk+3-devel libhandy1-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		if [ "$build_option_gir" ]; then
			vmove usr/share/eog/gir-1.0
		fi
	}
}
