libsensors_package() {
	short_desc="Library to read temperature/voltage/fan sensors"
	pkg_install() {
		vmove "usr/lib/*.so*"
	}
}

libsensors-devel_package() {
	depends="libsensors-${version}_${revision}"
	short_desc="lm-sensors development kit"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove usr/share/man/man3
	}
}

