LDFLAGS="-L${XBPS_CROSS_BASE}/usr/lib"
post_configure() {
	# Fix local posix_{open,close} name clash with unistd.h
	sed -e "s;posix_open;s_posix_open;g" \
		-e "s;posix_close;s_posix_close;g" \
		-i ${wrksrc}/lib/io/posix_io.c
}
