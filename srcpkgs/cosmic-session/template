# Template file for 'cosmic-session'
pkgname=cosmic-session
version=1.2.0
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all --features autostart"
hostmakedepends="just $(vopt_if sccache "rust-sccache")"
makedepends="glib"
depends="pop-fonts ttf-opensans"
short_desc="Session for the COSMIC desktop"
maintainer="Bella109 <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-session"
distfiles="https://github.com/pop-os/cosmic-session/archive/refs/tags/epoch-${version}.tar.gz"
checksum=94fc2244027809415515563e74526fe796c733750cdd97712f28d050d8c8f932
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
	vmkdir "usr/share/glib-2.0/schemas/"
	vinstall "${FILESDIR}/cosmic.session.gsettings.override" 644 "usr/share/glib-2.0/schemas/"
}

post_install() {
	glib-compile-schemas ${DESTDIR}/usr/share/glib-2.0/schemas >/dev/null 2>&1
}
