libnl-devel_package() {
	depends="libnl>=${version}"
	short_desc+=" -- development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
	}
}

libnl_package() {
	pkg_install() {
		vmove usr
