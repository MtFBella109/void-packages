libodbc_package() {
	short_desc="ODBC library for Unix"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

unixodbc-devel_package() {
	short_desc="ODBC library for Unix - development files"
	depends="libodbc-${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
	}
}
