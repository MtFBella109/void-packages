# Template file for 'cosmic-bg'
pkgname=cosmic-bg
version=1.0.16
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel mold"
depends="libxkbcommon"
short_desc="COSMIC session service which applies backgrounds to displays"
