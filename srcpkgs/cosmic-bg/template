# Template file for 'cosmic-bg'
pkgname=cosmic-bg
version=1.3.0
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel mold libdav1d-devel"
depends="libxkbcommon"
short_desc="COSMIC session service which applies backgrounds to displays"
maintainer="Bella109 <belladev109@proton.me>"
