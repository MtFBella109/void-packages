pre_configure() {
	cp /usr/bin/gettextize .
	sed -i '/read dummy/d' gettextize
	./gettextize -f
	sed '/PO_DEP/s/yes/no/' po/Makevars.template >po/Makevars
	autoreconf -f -i

	# Regenerate sources with new vala
	find -name '*.vala' -exec touch {} \;
}

