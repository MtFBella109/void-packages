subpackages="$pkgname-devel"


do_build() {
	export DEBUG=-DNDEBUG
	./configure ${CONFIGURE_SHARED_ARGS} \
		--enable-readline=yes --enable-blkid=yes --enable-lib64=no
	make ${makejobs}
}
