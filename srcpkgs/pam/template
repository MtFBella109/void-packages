do_configure() {
	./configure ${CONFIGURE_SHARED_ARGS} \
		--disable-selinux --libdir=/lib \
		--disable-rpath --docdir=/usr/share/doc/pam \
		--enable-read-both-confs DESTDIR=${DESTDIR}
}

do_build() {
	make ${makejobs}
}

