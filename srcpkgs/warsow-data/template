do_install() {
	vmkdir usr/share/warsow/basewsw
	vcopy "basewsw/*" usr/share/warsow/basewsw
	find ${DESTDIR}/usr/share/warsow -type d | xargs chmod 755
	find ${DESTDIR}/usr/share/warsow -type f | xargs chmod 644
	vlicense docs/license.txt
}
