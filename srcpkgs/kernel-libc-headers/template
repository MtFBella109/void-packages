	i686*|x86_64*) _arch="x86";;
	arm*) _arch="arm";;
	aarch64*) _arch="arm64";;
	mips*) _arch="mips";;
	ppc*) _arch="powerpc";;
	*) msg_error "$pkgname: unknown architecture.\n";;
esac

do_build() {
	make mrproper
	make ARCH="${_arch}" headers
}

