esac

babl-devel_package() {
	depends="lcms2-devel ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/share/vala
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove "usr/share/gir-*"
	}
}
