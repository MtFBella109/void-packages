case "$XBPS_TARGET_MACHINE" in
	armv6*)
		subpackages=" "
		;;
	armv7*)
		subpackages="rpi2-base"
		;;
	aarch64*)
		subpackages="rpi3-base rpi4-base"
		;;
esac

