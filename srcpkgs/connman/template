pre_configure() {
	case "$XBPS_TARGET_MACHINE" in
	*-musl)
		for f in ${FILESDIR}/musl/*.patch; do
			patch -Np1 -i $f
		done
		;;
	*)	export CFLAGS+=" -D_GNU_SOURCE";;
	esac
	autoreconf -fi
}
post_install() {
	# Install the client connmanctl.
	vbin client/connmanctl
	vsv connmand
}


