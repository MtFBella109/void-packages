# Template file for 'cosmic-files'
pkgname=cosmic-files
version=1.2.0
revision=1
archs="x86_64*"
build_style=cargo
configure_args="--all --no-default-features --features bzip2,dbus-config,desktop,gvfs,io-uring,lzma-rust2,notify,wayland,desktop-applet,jemalloc"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel libglib-devel"
depends="bzip2 glib liblzma libzstd libxkbcommon libmount libffi libpcre2 libblkid zlib xdg-utils"
short_desc="COSMIC file manager"
maintainer="Bella109 <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-files"
distfiles="https://github.com/pop-os/cosmic-files/archive/refs/tags/epoch-${version}.tar.gz"
checksum=1cbae3594d2b6b91ffa36abbbe96cd7c59f9f7df7e392d44685663f4c6a686c2
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
