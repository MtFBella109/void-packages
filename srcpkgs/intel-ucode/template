do_install() {
	vmkdir usr/lib/firmware/intel-ucode
	vcopy "intel-ucode/*" usr/lib/firmware/intel-ucode
	vmkdir usr/lib/dracut/dracut.conf.d
	echo "early_microcode=yes" >> ${DESTDIR}/usr/lib/dracut/dracut.conf.d/intel_ucode.conf
	vlicense license
}
