# Template file for 'cosmic-randr'
pkgname=cosmic-randr
version=1.0.14
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="just $(vopt_if sccache "rust-sccache")"
short_desc="Display and configure wayland display outputs"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="MPL-2.0"
homepage="https://github.com/pop-os/cosmic-randr"
distfiles="https://github.com/pop-os/cosmic-randr/archive/refs/tags/epoch-${version}.tar.gz"
checksum=6595b09c650816447f7d3332b2f62b0ed2d4d8b2ab06d88876853159a2daec3c
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
