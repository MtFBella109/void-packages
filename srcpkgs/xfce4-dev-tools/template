post_patch() {
	[ "$CROSS_BUILD" ] || return 0
	# For testing, which can't be run on cross build
	vsed -i -e '/^\ttest-xdt-csource\t/d' tests/Makefile.am
	vsed -i -e 's/^TESTS =.*/TESTS =/' \
		-e 's/^check_PROGRAMS =.*/check_PROGRAMS =/' \
		-e 's/\$.*xdt-csource --extern.*>/touch /' \
		tests/Makefile.in
}
