post_install() {
	vlicense LICENSE
	# Remove gdb python files.
	rm -f ${DESTDIR}/usr/lib/*.py
}

isl-devel_package() {
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
