pre_configure() {
	autoreconf -fi
}
post_install() {
	rm -r ${DESTDIR}/usr/share/man/man2
}

libnuma_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

libnuma-devel_package() {
	depends="libnuma>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/share/man/man3
		vmove usr/lib/pkgconfig
	}
}
