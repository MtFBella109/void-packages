mate-polkit-devel_package() {
	short_desc+=" - development files"
	depends="polkit-devel mate-polkit>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.so
		vmove usr/lib/pkgconfig
		if [ "$build_option_gir" ]; then
			vmove usr/share/gir-1.0
		fi
	}
}
