libupnp-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	conflicts="libupnp1.8-devel>=0"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove "usr/lib/*.a"
	}
}
