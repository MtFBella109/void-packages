Upstream gates these imports on the "systemd" feature, but their only use
(the lid-switch handler in src/input/mod.rs) is gated on "logind", which
the systemd feature merely implies. Building with --no-default-features
--features logind (as this template does) fails with unresolved
Switch/SwitchState/SwitchToggleEvent. Gating the import on "logind"
covers both feature combinations.

--- a/src/input/mod.rs
+++ b/src/input/mod.rs
@@ -35,7 +35,7 @@
 use cosmic_comp_config::{NumlockState, workspace::WorkspaceLayout};
 use cosmic_settings_config::shortcuts;
 use cosmic_settings_config::shortcuts::action::{Direction, ResizeDirection};
-#[cfg(feature = "systemd")]
+#[cfg(feature = "logind")]
 use smithay::backend::input::{Switch, SwitchState, SwitchToggleEvent};
 use smithay::{
     backend::input::{
