do_install() {
	CARGO_TARGET_DIR="target/${XBPS_RUST_TARGET}" make install
	vbin target/${XBPS_RUST_TARGET}/release/cosmic-comp
	vinstall data/cosmic.desktop 644 usr/share/wayland-session/cosmic.desktop
}
