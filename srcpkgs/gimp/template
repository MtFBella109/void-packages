subpackages="gimp-devel gimp-python"




gimp-python_package() {
	lib32disabled=yes
	depends="pygtk"
	pycompile_dirs="usr/lib/gimp/2.0/python"
	short_desc+=" - python bindings"
	pkg_install() {
		vmove usr/lib/gimp/2.0/python
		vmove "usr/lib/gimp/2.0/plug-ins/*.py"
	}
}
