libdvdnav-devel_package() {
	depends="libdvdread-devel libdvdnav>=${version}"
	short_desc+=" -- development files"
	pkg_install() {
		vmove usr/bin
		vmove usr/include
		vmove usr/share
		vmove usr/lib/pkgconfig
	}
}

