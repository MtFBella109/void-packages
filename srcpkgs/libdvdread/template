libdvdread-devel_package() {
	depends="libdvdread>=${version}"
	short_desc+=" -- development files"
	pkg_install() {
		vmove usr/bin
		vmove usr/include
		vmove usr/share
		vmove usr/lib/pkgconfig
	}
}

