serd-devel_package() {
	depends="libserd>=${version}_${revision}"
	short_desc+=" - Development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}

libserd_package() {
	short_desc+=" - Runtime library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}
