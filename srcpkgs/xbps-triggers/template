do_install() {
	_triggersdir=usr/libexec/${pkgname}

	for f in ${FILESDIR}/*; do
		_trigger=$(basename $f)
		vinstall ${FILESDIR}/${_trigger} 754 ${_triggersdir}
		echo "# end" >> ${DESTDIR}/${_triggersdir}/${_trigger}
	done
	vmkdir var/db/xbps
	cd ${DESTDIR}/var/db/xbps
	ln -sf ../../../${_triggersdir} triggers
}
