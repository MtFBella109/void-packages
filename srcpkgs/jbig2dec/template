pre_configure() {
	sed -i '$ d' autogen.sh
	./autogen.sh
}

post_install() {
	vlicense LICENSE
}

jbig2dec-devel_package() {
	short_desc+=" - development files"
	depends="libjbig2dec>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}

libjbig2dec_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}
