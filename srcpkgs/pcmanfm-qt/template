libfm-qt5_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove usr/lib/*.so.*
	}
}
libfm-qt5-devel_package() {
	short_desc+=" - development files"
	depends="libfm-qt5>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
