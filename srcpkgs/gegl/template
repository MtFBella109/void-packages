gegl-devel_package() {
	depends="json-glib-devel babl-devel ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/libgegl-0.4.so
		vmove usr/share/vala
		vmove usr/share/gir-1.0
	}
}
