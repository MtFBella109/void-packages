post_install() {
	vsv $pkgname
}

libhaveged_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove usr/lib/*.so.*
	}
}

libhaveged-devel_package() {
	short_desc+=" - development files"
	depends="libhaveged-${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.a
		vmove usr/lib/*.so
		vmove usr/share/man/man3
	}
}
