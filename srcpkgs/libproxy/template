libproxy-devel_package() {
	depends="libproxy>=${version}"
	short_desc+=" -- development files"
	pkg_install() {
		vmove usr/include
		vmove usr/share
		vmove usr/lib/pkgconfig
	}
}

libproxy-python_package() {
	depends="libproxy>=${version} python"
	short_desc+=" -- python bindings"
	pkg_install() {
		vmove "usr/lib/python*"
	}
}

