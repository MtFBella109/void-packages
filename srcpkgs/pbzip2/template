do_build() {
	sed -e 's,$(PREFIX)/man,$(PREFIX)/share/man,g' -i Makefile
	sed -e 's,\(ln -s -f \)$(PREFIX)/bin/,\1,' -i Makefile
	make CXX=$CXX CXXFLAGS="$CXXFLAGS $LDFLAGS"
}
do_install() {
	make PREFIX=${DESTDIR}/usr install
	vlicense COPYING
}
