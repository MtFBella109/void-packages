libwavpack_package() {
	short_desc+=" - shared library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

wavpack-devel_package() {
	depends="libwavpack>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
