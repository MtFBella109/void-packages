pre_configure() {
	case "$XBPS_TARGET_MACHINE" in
	arm*)	# Hack to not compile (broken) arm_neon.h inlining of indirect function calls
		vsed -i CMakeLists.txt -e "s;arm_neon.h;arm_neon.xxx;"
		;;
	esac
}
