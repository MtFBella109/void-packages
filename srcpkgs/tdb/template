tdb-devel_package() {
	depends="libtdb-${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}

tdb-python3_package() {
	short_desc+=" - Python3 bindings"
	depends="python3"
	pkg_install() {
		vmove ${py3_lib}
	}
}

libtdb_package() {
	short_desc+=" - shared libraries"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}
