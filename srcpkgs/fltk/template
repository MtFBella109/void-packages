post_install() {
	rm -rf ${DESTDIR}/usr/share/man/cat[13]
	vlicense COPYING
}

fltk-devel_package() {
	depends="${makedepends} fltk-${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/bin/fltk-config
		vmove usr/share/man/man1/fltk-config.1
		vmove usr/share/man/man3
		vmove usr/share/doc
		vmove usr/lib/*.so
		vmove usr/lib/*.a
	}
}
